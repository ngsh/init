{
  "env": {
    "HTTP_PROXY": "http://127.0.0.1:7890",
    "HTTPS_PROXY": "http://127.0.0.1:7890",
    "NO_PROXY": "127.0.0.1"
  },
  "permissions": {
    "deny": [
      "Read(~/**/secrets/**)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Read(~/**/*.pem)",
      "Read(~/**/*.key)",
      "Read(~/**/*.wif)",
      "Read(~/**/.wif)"
    ]
  }
}
